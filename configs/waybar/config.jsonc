{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 34, // Waybar height (to be removed for auto height)
    "width": 1914, // Waybar width
    "spacing": 12, // Gaps between modules (4px)
    "margin-top": 1,
    "margin-bottom": -1,

    "modules-left": [
        "niri/workspaces",
        "mpris"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "temperature",
        "memory",
        "cpu",
        "group/hw",
        "network",
        "battery"
    ],

   "custom/right": {
    "format": "", 
    "interval": "once",
    "tooltip": false
   },

    "niri/window": {
        "format": " {}",
        "max-length": 40,
        "tooltip": true,
        "separate-outputs": true
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%A, %d %B %H:%M}",
        "format-alt": "{:%H:%M}"
    },

    "cpu": {
        "format": " {usage}%",
        "on-click": "kitty -e btop",
        "tooltip": false
    },

    "memory": {
        "format": " {percentage}%",
        "on-click": "~/.local/bin/mem.sh"
    },

    "tray": {
      "icon-size": 16,
      "spacing" : 8
    },

    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}°C {icon}",
        "format": " {temperatureC}°C",
        "format-icons": ["󰉬", "", "󰉪"]
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["", "", ""],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-discharging": "{icon} {capacity}% - {time}",
        "format-full": "{capacity}% {icon}",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        //"format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""],
        "on-click": "~/.local/bin/bat.sh"
    },

    "battery#bat2": {
        "bat": "BAT2"
    },

    "network": {
        "max-length": 15,
        "format-wifi": " {signalStrength}%",
        "format-ethernet": "{ipaddr}/{cidr} 󰊗",
        "tooltip-format": "Network Information\n\nSSID  : {essid}\nIP    : {ipaddr}\nBand  : {frequency} MHz\nSignal: {signalStrength}%   \nvia   : {ifname}",
        "format-linked": "{ifname} (No IP) 󰊗",
        "format-disconnected": "󱛅",
        "on-click": "~/.local/bin/wifi.sh"
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": " {volume}%",
        //"format-bluetooth": "{volume}% {icon} {format_s" , //ource}",
        //"format-bluetooth-muted": "󰅶 {icon} {format_source}",
        "format-muted": "󰅶", //{format_source}",
        //"format-source": " {volume}%",
        //"format-source-muted": " ",
        "on-click": "pkill -x quickshell; QT_QPA_PLATFORMTHEME=gtk3 quickshell &"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "on-click": "pavucontrol",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
        "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
        "tooltip-format": "{source_desc} | {source_volume}%"
    },


/*
    "custom/weather": {
        "format": "{}°C",
        "tooltip": true,
        "interval": 5400,
        "exec": "~/.local/bin/wttrbar --nerd --hide-conditions --date-format '%m/%d' --mph --location=France",
        "return-type": "json",
        "on-click": "~/.local/bin/weather.sh"
    },
*/

    "group/cpu": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "temperature"
        ]
    },

    "mpris": {
        "format": "{player_icon} {title} - {artist}",
        "max-length": 40,
        "format-paused": "{status_icon} <i>{title} - {artist}</i>",
        "player-icons": {
            "default": "▶"
        },
        "status-icons": {
            "paused": "⏸"
        }
    },

    "group/hw": {
        "orientation": "horizontal",
        "modules": [
            "pulseaudio",
            "pulseaudio#microphone"
        ]
    }
}
