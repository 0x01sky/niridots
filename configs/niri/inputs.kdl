input {
    keyboard {
        xkb {
	    layout "fr"
            options "caps:escape"
        }
        numlock
    }

    touchpad {
        tap
        natural-scroll
        accel-speed 0.2
        disabled-on-external-mouse
    }
    mouse {
    }

    trackpoint {
   }
    focus-follows-mouse max-scroll-amount="0%"
}

gestures {
    hot-corners { off; }
}
