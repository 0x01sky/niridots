[global]
separator_color= frame
min_icon_size = 128
max_icon_size = 128
transparency = 20
frame_color = "#8e9099"
frame_width = 0
highlight = "#dcbce0"
font = JetBrainsMono Nerd font 13
width = (300, 700)
height = (50, 500)
progress_bar = true
progress_bar_height = 10
progress_bar_corner_radius = 4
progress_bar_frame_width = 1
progress_bar_min_width = 300
progress_bar_max_width = 300
padding = 6
origin = top-right
format = "<span foreground='#8a8a8aff'>%a</span>\n<b>%s</b>\n%b"


[urgency_low]
    background = "#262a2fBF"
    foreground = "#e2e2e9"

[urgency_normal]
    background = "#262a2fBF"
    foreground = "#e2e2e9"

[urgency_critical]
    background = "#93000aBF"
    foreground = "#ffdad6"

